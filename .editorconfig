# EditorConfig helps maintain consistent coding styles
root = true

# All files
[*]
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# Java files
[*.java]
indent_size = 4
max_line_length = 120
continuation_indent_size = 8

# XML files
[*.{xml,pom}]
indent_size = 2

# YAML files
[*.{yaml,yml}]
indent_size = 2

# Properties files
[*.properties]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 100

# JSON files
[*.json]
indent_size = 2

# Shell scripts
[*.{sh,bash}]
indent_size = 2
end_of_line = lf
