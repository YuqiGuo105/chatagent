# =========================================================
# writer-service environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# =========================================================

# ---- Supabase Postgres (Database) ----
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string → JDBC
# Use the "Session pooler" (port 5432) URL. `sslmode=require` is mandatory.
#
# Format:
#   jdbc:postgresql://<HOST>:5432/postgres?sslmode=require
#
# Example (region will differ for your project):
#   jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
WRITER_DB_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# For Supabase the username is usually:  postgres.<project-ref>
WRITER_DB_USERNAME=postgres.your-project-ref

# Your Supabase database password (set when project was created, or rotated in dashboard)
WRITER_DB_PASSWORD=your-supabase-db-password

# ---- Admin auth ----
# Dev placeholder. In production, swap AdminTokenFilter for Supabase Auth JWT validation
# and restrict to the admin email allow-list.
WRITER_ADMIN_TOKEN=dev-secret-change-me

# ---- Outbox poller (optional) ----
OUTBOX_POLL_INTERVAL_MS=5000

# ---- Event publisher ----
# `pg-notify` (default): broadcasts via Postgres NOTIFY — picked up by Supabase Realtime
# `noop`: logs only (no downstream events)
WRITER_PUBLISHER_TYPE=pg-notify
WRITER_PUBLISHER_CHANNEL=writer_content_events

# ---- Future: Kafka on Railway ----
# Optional second hop after pg_notify. Supabase does NOT host Kafka.
# KAFKA_BOOTSTRAP_SERVERS=tramway.proxy.rlwy.net:12345
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
